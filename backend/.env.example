NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-app.vercel.app

# PostgreSQL connection string (use a pooled URL in serverless environments,
# e.g. Supabase pgbouncer, Neon, or Vercel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/triprodeo

JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ADMIN_DEFAULT_EMAIL=admin@triprodeo.com
ADMIN_DEFAULT_PASSWORD=replace_me

CMS_ADMIN_SECRET=replace_me

SITE_URL=https://triprodeo.com
SITE_NAME=Triprodeo
SITE_DESCRIPTION=India's premier luxury villa and resort booking platform
